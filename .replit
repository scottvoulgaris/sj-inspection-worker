modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["chromium"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Automation Worker"

[[workflows.workflow]]
name = "Automation Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "cloudrun"
run = ["node", "index.js"]

[userenv]

[userenv.shared]
CONTROL_APP_URL = "https://inspection-scheduler-accelerator.replit.app/"
DRY_RUN = "false"
PORTAL_USERNAME = "permits@aro.homes"
PORTAL_PASSWORD = "Aroconstruction1"

[[ports]]
localPort = 3000
externalPort = 80
